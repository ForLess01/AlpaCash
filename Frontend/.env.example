# ============================================================
# AlpaCash Frontend (Next.js) — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in the values.
#
# PERSONAL DEPLOY — Frontend runs on Render:
#   1. Ensure foundation.sql has been run on your Supabase project.
#   2. Find URL and anon key in Supabase Dashboard → Project Settings → API.
#   3. Set NEXT_PUBLIC_API_URL to your deployed Backend Vercel URL.
#   4. Configure these vars in Render → Service → Environment Variables.
#
# TEAM HANDOFF:
#   Replace with team Supabase project credentials and backend URL.
# ============================================================

# Supabase project URL (must match Backend SUPABASE_URL)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon key (safe — restricted by RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Deployed backend API base URL — Backend is on Vercel (no trailing slash)
# For local dev: http://localhost:3001
NEXT_PUBLIC_API_URL=https://your-backend-app.vercel.app

# Frontend deployment URL (for CORS and redirects) — Frontend is on Render
NEXT_PUBLIC_APP_URL=https://your-frontend-app.onrender.com
