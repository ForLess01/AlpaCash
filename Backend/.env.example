# ============================================================
# AlpaCash Backend — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values for your
# target environment (personal validation or team production).
#
# PERSONAL DEPLOY — Backend runs on Vercel:
#   1. Run supabase/foundation.sql on your personal Supabase project.
#   2. Run supabase/auth-policies.sql immediately after.
#   3. Find your project URL and keys in Supabase Dashboard → API.
#   4. Set FRONTEND_URL to your Render frontend service URL (see Frontend/.env.example).
#   5. Configure these vars in Vercel → Project → Environment Variables.
#
# TEAM HANDOFF:
#   Replace values with team Supabase project credentials.
#   SQL scripts are identical; only env vars differ.
# ============================================================

# Supabase project URL (Dashboard → Project Settings → API)
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/publishable key (safe for browser — used for RLS-protected calls)
SUPABASE_PUBLISHABLE_KEY=eyJ...

# Supabase service_role/secret key (NEVER expose to frontend)
# Used by supabaseAdmin for server-side operations (bypasses RLS)
SUPABASE_SECRET_KEY=eyJ...

# Allowed CORS origin — must match the deployed frontend URL (Render service)
# For local dev: http://localhost:3000
FRONTEND_URL=https://your-frontend-app.onrender.com

# Runtime environment
NODE_ENV=production
